<!DOCTYPE html>
<html>
<head>
<title>Services Page</title>
<style>
body{
    font-family:Arial;
    margin:0;
    background:#f2f2f2;
}

/* Header */
header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 40px;
    background:white;
}

.logo{
    border:2px solid black;
    border-radius:50px;
    padding:5px 20px;
    font-weight:bold;
}

nav a{
    text-decoration:none;
    margin-left:20px;
    color:pink;
}

nav a.active{
    text-decoration:underline;
}

/* Banner */
.banner{
    height:160px;
    margin:20px;
    border-radius:5px;
    background:linear-gradient(to right, blue);
}

/* Boxes Container */
.box-row{
    display:flex;
    justify-content:center;
    gap:20px;
    margin-bottom:20px;
}

.box{
    width:150px;
    height:80px;
    background:#ddd;
    border:2px solid blue;
    border-radius:5px;
    display:flex;
    align-items:center;
    justify-content:center;
}

/* Footer */
footer{
    text-align:center;
    padding:15px;
    border-top:2px solid blue;
    margin-top:20px;
}
</style>
</head>
